# ================ 服务 ================
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ================ MongoDB ================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=xhs_sentiment

# ================ Redis ================
REDIS_URL=redis://localhost:6379/0

# ================ TikHub API ================
# 注册并获取 token: https://tikhub.io
TIKHUB_BASE_URL=https://api.tikhub.dev
TIKHUB_FALLBACK_BASE_URL=https://api.tikhub.io
TIKHUB_TOKEN=
TIKHUB_REQUEST_TIMEOUT_SECONDS=15

# ================ 采集 ================
COLLECT_INTERVAL_MINUTES=30
MAX_NOTES_PER_PAGE=20
MAX_COMMENTS_PER_NOTE=100
COMMENTS_REFRESH_HOURS=6

# ================ 监控目标 ================
# 三模块关键词（推荐使用，JSON 数组格式）
MONITOR_KEYWORDS_BRAND=["渊学通","学通","yxt"]
MONITOR_KEYWORDS_COMPETITOR=["新东方","启德"]
MONITOR_KEYWORDS_INDUSTRY=["alevel","雅思","国际学校"]

# 以下为旧版配置，已废弃，保留向后兼容
MONITOR_KEYWORDS=[]
MONITOR_TAGS=[]
COMPETITORS=[]

# ================ 情感分析 ================
# provider: llm（大模型）| senta（百度ERNIE）| rule（规则，默认）
SENTIMENT_PROVIDER=llm
# LLM 配置（MiniMax / GLM / DeepSeek 等 OpenAI 兼容接口）
SENTIMENT_API_BASE=https://api.minimax.chat/v1
SENTIMENT_API_KEY=
SENTIMENT_MODEL=MiniMax-M2.7
SENTIMENT_BATCH_SIZE=20
SENTIMENT_CACHE_TTL=3600

# ================ WebSocket ================
WS_HEARTBEAT_INTERVAL=30
